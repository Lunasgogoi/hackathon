PROJECT_NAME=HackCore
SECRET_KEY=change_me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/hackathon_db
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ENABLE_DEV_ROUTES=false

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_USE_TLS=true
APP_PUBLIC_URL=http://127.0.0.1:5173

MASTER_ADMIN_USERNAME=masteradmin
MASTER_ADMIN_EMAIL=admin@example.com
MASTER_ADMIN_PASSWORD=StrongAdminPass2026!

# true = use the remote Piston API. false = use Docker-isolated execution.
# Piston failures return 503 instead of falling back silently.
USE_PISTON_CODE_RUNNER=true
PISTON_EXECUTE_URL=https://emkc.org/api/v2/piston/execute

# Used when USE_PISTON_CODE_RUNNER=false. Docker must be installed on the API host.
PYTHON_RUNNER_IMAGE=python:3.10-slim
JAVASCRIPT_RUNNER_IMAGE=node:18-slim
CPP_RUNNER_IMAGE=gcc:12
CODE_RUNNER_MEMORY_LIMIT=128m
CODE_RUNNER_CPUS=1
CODE_RUNNER_PIDS_LIMIT=64
CODE_RUNNER_TMPFS_SIZE=64m
CODE_RUNNER_COMPILE_TIMEOUT_SECONDS=10
